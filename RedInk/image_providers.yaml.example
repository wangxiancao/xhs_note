# 图片生成服务商配置
# 复制此文件为 image_providers.yaml 并填写你的配置

# 当前激活的服务商（填写下方 providers 中的名称）
active_provider: glm_image

# 服务商列表
providers:
  # GLM-Image（默认推荐）
  glm_image:
    type: image_api
    api_key: sk-xxxxxxxxxxxxxxxxxxxx
    base_url: https://open.bigmodel.cn/api/paas
    endpoint_type: /v4/images/generations
    model: glm-image
    default_aspect_ratio: 3:4
    # 去水印开关（需先在 BigModel 平台签署免责声明并开通能力）
    # true: 保留水印（默认）
    # false: 去除水印
    # 不填: 使用平台默认策略
    watermark_enabled: true
    high_concurrency: false

  # OpenAI 图像接口（可选）
  openai_image:
    type: image_api
    api_key: sk-xxxxxxxxxxxxxxxxxxxx
    base_url: https://api.openai.com
    endpoint_type: /v1/images/generations
    model: dall-e-3
    high_concurrency: false

  # DeepSeek 生态常配（硅基流动 FLUX，可选）
  siliconflow_flux:
    type: image_api
    api_key: sk-xxxxxxxxxxxxxxxxxxxx
    base_url: https://api.siliconflow.cn/v1
    endpoint_type: /images/generations
    model: black-forest-labs/FLUX.1-schnell
    high_concurrency: false

  # 即梦/豆包类接口（可选，需按服务商文档调整 model 与 endpoint）
  jimeng_chat_api:
    type: image_api
    api_key: sk-xxxxxxxxxxxxxxxxxxxx
    base_url: https://ark.cn-beijing.volces.com/api/v3
    endpoint_type: /chat/completions
    model: doubao-seedream-3-0-t2i-250415
    short_prompt: true
    high_concurrency: false
