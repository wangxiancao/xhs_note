# 图片生成服务商配置
# 复制此文件为 image_providers.yaml 并填写你的配置

# 当前激活的服务商（填写下方 providers 中的名称）
active_provider: glm_image

# 服务商列表
providers:
  # GLM-Image（默认推荐）
  glm_image:
    type: image_api
    api_key: sk-xxxxxxxxxxxxxxxxxxxx # 也可留空，运行时从 .claude/CLAUDE.md 或环境变量读取
    base_url: https://open.bigmodel.cn/api/paas
    endpoint_type: /v4/images/generations
    model: glm-image
    default_aspect_ratio: 3:4
    high_concurrency: false

  # OpenAI 图像接口（可选）
  openai_image:
    type: image_api
    api_key: sk-xxxxxxxxxxxxxxxxxxxx
    base_url: https://api.openai.com
    endpoint_type: /v1/images/generations
    model: dall-e-3
    high_concurrency: false
